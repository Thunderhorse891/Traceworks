import { buildReport, reportToHtml, reportToText } from './report.js';
import { sendReportEmails } from './email.js';
import { gatherOsint } from './osint.js';
import { gatherPublicRecordIntel, publicRecordEvidenceToSources } from './public-records.js';

function mergeIntel(osint = {}, publicRecordIntel = null) {
  const osintSources = Array.isArray(osint.sources) ? osint.sources : [];
  const publicSources = Array.isArray(publicRecordIntel?.sources)
    ? publicRecordIntel.sources
    : publicRecordEvidenceToSources(publicRecordIntel?.evidence || []);

  const mergedSources = [...osintSources, ...publicSources];

  const distinctDomains = new Set(
    mergedSources
      .map((source) => source?.domain || '')
      .filter(Boolean)
  ).size;

  const providersWithHits = new Set(
    mergedSources
      .map((source) => source?.provider || source?.sourceType || '')
      .filter(Boolean)
  ).size;

  const providerNotes = [];
  if (osint?.providerNote) providerNotes.push(osint.providerNote);
  if (publicRecordIntel?.gaps?.length) {
    providerNotes.push(`Public record gaps: ${publicRecordIntel.gaps.join('; ')}`);
  }

  return {
    ...osint,
    publicRecords: publicRecordIntel,
    sources: mergedSources,
    queryPlan: [
      ...(Array.isArray(osint?.queryPlan) ? osint.queryPlan : []),
      ...(publicRecordIntel?.input?.address ? [publicRecordIntel.input.address] : []),
      ...(publicRecordIntel?.input?.ownerName ? [publicRecordIntel.input.ownerName] : []),
      ...(publicRecordIntel?.input?.decedentName ? [publicRecordIntel.input.decedentName] : []),
    ].filter(Boolean),
    coverage: {
      totalSources: mergedSources.length,
      distinctDomains,
      providersWithHits,
    },
    providerNote: providerNotes.join(' '),
  };
}

export async function processFulfillmentJob(job, { ownerEmail }) {
  const payload = job.payload || {};

  const publicRecordIntel = await gatherPublicRecordIntel(payload);

  const osint = await gatherOsint(
    `${payload.companyName || ''} ${payload.website || ''} ${payload.goals || ''}`.trim(),
    { packageId: payload.packageId }
  );

  const intel = mergeIntel(osint, publicRecordIntel);

  const report = buildReport({
    caseRef: payload.caseRef,
    packageId: payload.packageId,
    customerName: payload.customerName,
    customerEmail: payload.customerEmail,
    companyName: payload.companyName,
    website: payload.website,
    goals: payload.goals,
    intel,
  });

  await sendReportEmails({
    ownerEmail,
    customerEmail: report.customerEmail,
    subject: `[${report.caseRef}] Your ${report.package} report is ready`,
    textBody: reportToText(report),
    htmlBody: reportToHtml(report),
  });

  return {
    report,
    publicRecordIntel,
    osint,
  };
}
